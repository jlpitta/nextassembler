manifest {
    name        = 'nextassembler'
    version     = '1.0.0'
    description = 'Long-Read Genome Assembly Pipeline'
    author      = 'jlpitta'
    nextflowVersion = '>=23.04.0'
}

params {
    // Input
    samplesheet     = null
    long_reads      = null
    short_reads_1   = null
    short_reads_2   = null
    sample_name     = 'sample'
    genome_size     = null

    // Mode
    mode            = 'denovo'

    // Polishing
    use_racon         = false
    polisher          = 'polypolish'  // polypolish (default), nextpolish, none
    nextpolish_rounds = 1             // apenas para --polisher nextpolish

    // Platform
    platform        = 'mgicyclone'
    medaka_model    = null   // definido pelo platform; sobrescreve com --medaka_model
    flye_mode       = null   // definido pelo platform; sobrescreve com --flye_mode

    // Filtering
    min_quality     = 10
    min_length      = 500
    downsample      = 0

    // Reference
    reference       = null

    // Resources
    t               = 8
    outdir          = 'results'

    // Help
    help            = false
}

conda.enabled  = true
conda.useMamba = true

def max_cpus = Runtime.runtime.availableProcessors()

if (params.t > max_cpus) {
    log.warn "Requested --t ${params.t} exceeds available CPUs (${max_cpus}) on this machine — capping to ${max_cpus}."
}

executor {
    name = 'local'
    cpus = { Math.min(params.t as int, max_cpus) }
}

process {
    cache = 'lenient'

    withLabel: 'process_low' {
        cpus = { Math.max(1, (Math.min(params.t as int, max_cpus) / 4).toInteger()) }
    }
    withLabel: 'process_medium' {
        cpus = { Math.max(1, (Math.min(params.t as int, max_cpus) / 2).toInteger()) }
    }
    withLabel: 'process_high' {
        cpus = { Math.min(params.t as int, max_cpus) }
    }
}

profiles {
    conda      { conda.useMamba = false }
    mamba      { /* default */ }
    micromamba { conda.mambaBin = 'micromamba' }
}
